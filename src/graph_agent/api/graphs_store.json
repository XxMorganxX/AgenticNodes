{
  "graphs": [
    {
      "graph_id": "test-environment",
      "name": "Multi-Agent Test Environment",
      "description": "Default playground with isolated sub-agents that can be focused individually in the visualizer and run drawer.",
      "version": "1.0",
      "graph_type": "test_environment",
      "env_vars": {
        "OPENAI_API_KEY": "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY": "ANTHROPIC_API_KEY"
      },
      "agents": [
        {
          "agent_id": "research-agent",
          "name": "Research Agent",
          "description": "Explores the tool catalog, gathers context, and produces a short research summary.",
          "version": "1.0",
          "start_node_id": "research_start",
          "nodes": [
            {
              "id": "research_start",
              "kind": "input",
              "category": "start",
              "label": "Research Input",
              "provider_id": "start.manual_run",
              "provider_label": "Run Button Start",
              "description": "Seeds the research workflow.",
              "position": { "x": 40, "y": 150 },
              "config": { "input_binding": { "type": "input_payload" } }
            },
            {
              "id": "research_query",
              "kind": "model",
              "category": "api",
              "label": "Frame Research Query",
              "provider_id": "core.api",
              "provider_label": "API Call Node",
              "description": "Converts the request into a tool-ready search query.",
              "model_provider_name": "mock",
              "prompt_name": "research_query",
              "position": { "x": 420, "y": 150 },
              "config": {
                "provider_name": "mock",
                "model": "mock-default",
                "prompt_name": "research_query",
                "mode": "research_query",
                "system_prompt": "Turn the user request into a compact catalog search payload.",
                "user_message_template": "Request: {user_request}",
                "response_mode": "tool_call",
                "preferred_tool_name": "search_catalog",
                "allowed_tool_names": ["search_catalog"],
                "metadata_bindings": {
                  "user_request": { "type": "latest_payload", "source": "research_start" }
                }
              }
            },
            {
              "id": "research_tool",
              "kind": "tool",
              "category": "tool",
              "label": "Search Catalog",
              "provider_id": "tool.registry",
              "provider_label": "Registry Tool Node",
              "description": "Looks up relevant tools and examples.",
              "tool_name": "search_catalog",
              "position": { "x": 800, "y": 150 },
              "config": {
                "tool_name": "search_catalog",
                "input_binding": {
                  "type": "first_available_envelope",
                  "sources": ["research_query"]
                }
              }
            },
            {
              "id": "research_summary",
              "kind": "model",
              "category": "api",
              "label": "Summarize Findings",
              "provider_id": "core.api",
              "provider_label": "API Call Node",
              "description": "Builds a concise response from the tool results.",
              "model_provider_name": "mock",
              "prompt_name": "research_summary",
              "position": { "x": 1180, "y": 150 },
              "config": {
                "provider_name": "mock",
                "model": "mock-default",
                "prompt_name": "research_summary",
                "mode": "research_summary",
                "system_prompt": "Summarize the catalog findings for the current task.",
                "user_message_template": "Tool result: {tool_result}",
                "response_mode": "message",
                "metadata_bindings": {
                  "tool_result": { "type": "latest_payload", "source": "research_tool" }
                }
              }
            },
            {
              "id": "research_finish",
              "kind": "output",
              "category": "end",
              "label": "Research Output",
              "provider_id": "core.output",
              "provider_label": "Core Output Node",
              "description": "Returns the research summary.",
              "position": { "x": 1540, "y": 150 },
              "config": {
                "source_binding": {
                  "type": "latest_envelope",
                  "source": "research_summary"
                }
              }
            }
          ],
          "edges": [
            { "id": "research-start-query", "source_id": "research_start", "target_id": "research_query", "label": "begin", "kind": "standard", "priority": 100, "condition": null },
            { "id": "research-query-tool", "source_id": "research_query", "target_id": "research_tool", "label": "search", "kind": "standard", "priority": 100, "condition": null },
            { "id": "research-tool-summary", "source_id": "research_tool", "target_id": "research_summary", "label": "summarize", "kind": "standard", "priority": 100, "condition": null },
            { "id": "research-summary-finish", "source_id": "research_summary", "target_id": "research_finish", "label": "deliver", "kind": "standard", "priority": 100, "condition": null }
          ]
        },
        {
          "agent_id": "planner-agent",
          "name": "Planner Agent",
          "description": "Produces a plan and includes separate success and clarification end states.",
          "version": "1.0",
          "start_node_id": "planner_start",
          "nodes": [
            {
              "id": "planner_start",
              "kind": "input",
              "category": "start",
              "label": "Planning Input",
              "provider_id": "start.manual_run",
              "provider_label": "Run Button Start",
              "description": "Seeds the planning workflow.",
              "position": { "x": 40, "y": 150 },
              "config": { "input_binding": { "type": "input_payload" } }
            },
            {
              "id": "planner_model",
              "kind": "model",
              "category": "api",
              "label": "Draft Plan",
              "provider_id": "core.api",
              "provider_label": "API Call Node",
              "description": "Drafts a plan for the task and can branch to different outcomes.",
              "model_provider_name": "mock",
              "prompt_name": "planner_draft",
              "position": { "x": 460, "y": 150 },
              "config": {
                "provider_name": "mock",
                "model": "mock-default",
                "prompt_name": "planner_draft",
                "mode": "planner_draft",
                "system_prompt": "Create a short action plan from the request.",
                "user_message_template": "Request: {user_request}",
                "response_mode": "message",
                "metadata_bindings": {
                  "user_request": { "type": "latest_payload", "source": "planner_start" }
                }
              }
            },
            {
              "id": "planner_ready",
              "kind": "output",
              "category": "end",
              "label": "Plan Ready",
              "provider_id": "core.output",
              "provider_label": "Core Output Node",
              "description": "Returns a ready-to-execute plan.",
              "position": { "x": 900, "y": 80 },
              "config": {
                "source_binding": {
                  "type": "latest_envelope",
                  "source": "planner_model"
                }
              }
            },
            {
              "id": "planner_clarify",
              "kind": "output",
              "category": "end",
              "label": "Needs Clarification",
              "provider_id": "core.output",
              "provider_label": "Core Output Node",
              "description": "Represents the alternate clarification endpoint for this agent.",
              "position": { "x": 900, "y": 250 },
              "config": {
                "source_binding": {
                  "type": "latest_envelope",
                  "source": "planner_model"
                }
              }
            }
          ],
          "edges": [
            { "id": "planner-start-model", "source_id": "planner_start", "target_id": "planner_model", "label": "begin", "kind": "standard", "priority": 100, "condition": null },
            {
              "id": "planner-model-clarify",
              "source_id": "planner_model",
              "target_id": "planner_clarify",
              "label": "needs more detail",
              "kind": "conditional",
              "priority": 10,
              "condition": {
                "id": "planner-needs-clarification",
                "label": "Needs clarification",
                "type": "result_status_equals",
                "value": "validation_error"
              }
            },
            { "id": "planner-model-ready", "source_id": "planner_model", "target_id": "planner_ready", "label": "ready", "kind": "standard", "priority": 100, "condition": null }
          ]
        },
        {
          "agent_id": "executor-agent",
          "name": "Executor Agent",
          "description": "Proposes an action, runs a tool, then validates and returns the execution result.",
          "version": "1.0",
          "start_node_id": "executor_start",
          "nodes": [
            {
              "id": "executor_start",
              "kind": "input",
              "category": "start",
              "label": "Execution Input",
              "provider_id": "start.manual_run",
              "provider_label": "Run Button Start",
              "description": "Seeds the execution workflow.",
              "position": { "x": 40, "y": 150 },
              "config": { "input_binding": { "type": "input_payload" } }
            },
            {
              "id": "executor_plan",
              "kind": "model",
              "category": "api",
              "label": "Propose Action",
              "provider_id": "core.api",
              "provider_label": "API Call Node",
              "description": "Converts the request into a concrete tool action.",
              "model_provider_name": "mock",
              "prompt_name": "executor_plan",
              "position": { "x": 420, "y": 150 },
              "config": {
                "provider_name": "mock",
                "model": "mock-default",
                "prompt_name": "executor_plan",
                "mode": "executor_plan",
                "system_prompt": "Produce a tool call that advances the task.",
                "user_message_template": "Request: {user_request}",
                "response_mode": "tool_call",
                "preferred_tool_name": "search_catalog",
                "allowed_tool_names": ["search_catalog"],
                "metadata_bindings": {
                  "user_request": { "type": "latest_payload", "source": "executor_start" }
                }
              }
            },
            {
              "id": "executor_tool",
              "kind": "tool",
              "category": "tool",
              "label": "Execute Tool",
              "provider_id": "tool.registry",
              "provider_label": "Registry Tool Node",
              "description": "Runs the proposed action.",
              "tool_name": "search_catalog",
              "position": { "x": 800, "y": 150 },
              "config": {
                "tool_name": "search_catalog",
                "input_binding": {
                  "type": "first_available_envelope",
                  "sources": ["executor_plan"]
                }
              }
            },
            {
              "id": "executor_validate",
              "kind": "model",
              "category": "api",
              "label": "Validate Result",
              "provider_id": "core.api",
              "provider_label": "API Call Node",
              "description": "Checks the execution result before returning it.",
              "model_provider_name": "mock",
              "prompt_name": "executor_validate",
              "position": { "x": 1180, "y": 150 },
              "config": {
                "provider_name": "mock",
                "model": "mock-default",
                "prompt_name": "executor_validate",
                "mode": "executor_validate",
                "system_prompt": "Validate the tool result and return a concise status update.",
                "user_message_template": "Tool result: {tool_result}",
                "response_mode": "message",
                "metadata_bindings": {
                  "tool_result": { "type": "latest_payload", "source": "executor_tool" }
                }
              }
            },
            {
              "id": "executor_finish",
              "kind": "output",
              "category": "end",
              "label": "Execution Output",
              "provider_id": "core.output",
              "provider_label": "Core Output Node",
              "description": "Returns the execution summary.",
              "position": { "x": 1540, "y": 150 },
              "config": {
                "source_binding": {
                  "type": "latest_envelope",
                  "source": "executor_validate"
                }
              }
            }
          ],
          "edges": [
            { "id": "executor-start-plan", "source_id": "executor_start", "target_id": "executor_plan", "label": "begin", "kind": "standard", "priority": 100, "condition": null },
            { "id": "executor-plan-tool", "source_id": "executor_plan", "target_id": "executor_tool", "label": "execute", "kind": "standard", "priority": 100, "condition": null },
            { "id": "executor-tool-validate", "source_id": "executor_tool", "target_id": "executor_validate", "label": "validate", "kind": "standard", "priority": 100, "condition": null },
            { "id": "executor-validate-finish", "source_id": "executor_validate", "target_id": "executor_finish", "label": "deliver", "kind": "standard", "priority": 100, "condition": null }
          ]
        }
      ]
    },
    {
      "graph_id": "tool-schema-repair",
      "name": "Tool Schema Repair Example",
      "description": "Demonstrates a model -> tool -> repair -> model loop using the shared graph envelope contract.",
      "version": "1.0",
      "start_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "kind": "input",
          "category": "start",
          "label": "Start Input",
          "provider_id": "start.manual_run",
          "provider_label": "Run Button Start",
          "description": "Captures the starting payload for a graph run.",
          "position": { "x": 40, "y": 135 },
          "config": { "input_binding": { "type": "input_payload" } }
        },
        {
          "id": "propose_tool",
          "kind": "model",
          "category": "api",
          "label": "Propose Tool Payload",
          "provider_id": "core.api",
          "provider_label": "API Call Node",
          "description": "Creates the first tool payload attempt and routes it to the tool node.",
          "model_provider_name": "mock",
          "prompt_name": "schema_proposal",
          "position": { "x": 440, "y": 135 },
          "config": {
            "provider_name": "mock",
            "model": "mock-default",
            "prompt_name": "schema_proposal",
            "mode": "schema_proposal",
            "system_prompt": "You are designing input for a tool call.\nGiven a user request, produce a JSON object for the requested tool.\nReturn only fields required by the schema and prefer the smallest valid payload.",
            "user_message_template": "Request: {user_request}\\nAvailable tools: {available_tools}",
            "response_mode": "tool_call",
            "preferred_tool_name": "search_catalog",
            "allowed_tool_names": ["search_catalog"],
            "metadata_bindings": {
              "user_request": { "type": "latest_payload", "source": "start" }
            }
          }
        },
        {
          "id": "run_tool",
          "kind": "tool",
          "category": "tool",
          "label": "Run Tool",
          "provider_id": "tool.registry",
          "provider_label": "Registry Tool Node",
          "description": "Validates and runs the selected tool.",
          "tool_name": "search_catalog",
          "position": { "x": 840, "y": 135 },
          "config": {
            "tool_name": "search_catalog",
            "input_binding": {
              "type": "first_available_envelope",
              "sources": ["repair_tool", "propose_tool"]
            }
          }
        },
        {
          "id": "repair_tool",
          "kind": "model",
          "category": "api",
          "label": "Repair Tool Payload",
          "provider_id": "core.api",
          "provider_label": "API Call Node",
          "description": "Repairs the tool payload after validation failure.",
          "model_provider_name": "mock",
          "prompt_name": "schema_repair",
          "position": { "x": 1240, "y": 40 },
          "config": {
            "provider_name": "mock",
            "model": "mock-default",
            "prompt_name": "schema_repair",
            "mode": "schema_repair",
            "system_prompt": "The previous tool payload failed validation.\nRepair the tool input using the original request and the validation error details.\nReturn a corrected JSON object and avoid repeating the same mistake.",
            "user_message_template": "Request: {user_request}\\nValidation error: {tool_error}\\nAvailable tools: {available_tools}",
            "response_mode": "tool_call",
            "preferred_tool_name": "search_catalog",
            "allowed_tool_names": ["search_catalog"],
            "metadata_bindings": {
              "user_request": { "type": "latest_payload", "source": "start" },
              "tool_error": { "type": "latest_error", "source": "run_tool" }
            }
          }
        },
        {
          "id": "compose_response",
          "kind": "model",
          "category": "api",
          "label": "Compose Final Response",
          "provider_id": "core.api",
          "provider_label": "API Call Node",
          "description": "Builds the response shown to the user.",
          "model_provider_name": "mock",
          "prompt_name": "final_response",
          "position": { "x": 1240, "y": 250 },
          "config": {
            "provider_name": "mock",
            "model": "mock-default",
            "prompt_name": "final_response",
            "mode": "final_response",
            "system_prompt": "Given the original request, the intermediate tool results, and the graph history,\nproduce a concise final response for the user.",
            "user_message_template": "Request: {user_request}\\nTool result: {tool_result}",
            "response_mode": "message",
            "metadata_bindings": {
              "user_request": { "type": "latest_payload", "source": "start" },
              "tool_result": { "type": "latest_payload", "source": "run_tool" }
            }
          }
        },
        {
          "id": "finish",
          "kind": "output",
          "category": "end",
          "label": "Output Response",
          "provider_id": "core.output",
          "provider_label": "Core Output Node",
          "description": "Returns the final response payload.",
          "position": { "x": 1640, "y": 250 },
          "config": {
            "source_binding": {
              "type": "latest_envelope",
              "source": "compose_response"
            }
          }
        }
      ],
      "edges": [
        { "id": "edge-start-propose", "source_id": "start", "target_id": "propose_tool", "label": "begin", "kind": "standard", "priority": 100, "condition": null },
        { "id": "edge-propose-run", "source_id": "propose_tool", "target_id": "run_tool", "label": "try tool", "kind": "standard", "priority": 100, "condition": null },
        {
          "id": "edge-run-repair",
          "source_id": "run_tool",
          "target_id": "repair_tool",
          "label": "repair invalid schema",
          "kind": "conditional",
          "priority": 10,
          "condition": {
            "id": "tool_validation_failed",
            "label": "Tool validation failed",
            "type": "result_status_equals",
            "value": "validation_error"
          }
        },
        { "id": "edge-run-compose", "source_id": "run_tool", "target_id": "compose_response", "label": "tool succeeded", "kind": "standard", "priority": 100, "condition": null },
        { "id": "edge-repair-run", "source_id": "repair_tool", "target_id": "run_tool", "label": "retry tool", "kind": "standard", "priority": 100, "condition": null },
        { "id": "edge-compose-finish", "source_id": "compose_response", "target_id": "finish", "label": "finalize", "kind": "standard", "priority": 100, "condition": null }
      ]
    }
  ]
}