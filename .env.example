GRAPH_AGENT_HOST=127.0.0.1
GRAPH_AGENT_PORT=8000
# Optional: only when the UI must call the API on another host (omit for `python run.py` — Vite proxies /api).
# VITE_API_BASE_URL=http://127.0.0.1:8000
# If you run `npm run dev` alone, proxy target defaults to :8000; override when the API uses another port:
# GRAPH_AGENT_API_PROXY=http://127.0.0.1:8001
DISCORD_BOT_TOKEN=
APOLLO_API_KEY=
# Cloudflare tunnel token — required when graphs use inbound-webhook listener
# start nodes (e.g. start.webhook, future). The Cloudflare config UI stores the
# env-var NAME (default CLOUDFLARE_TUNNEL_TOKEN), not the secret value itself.
CLOUDFLARE_TUNNEL_TOKEN=
# Machine-local folder used by LinkedIn Profile Fetch nodes. Keep graph node config as {LINKEDIN_DATA_DIR}.
# LINKEDIN_DATA_DIR=~/Desktop/Linkedin Data
# Persist every run + its resolved per-node prompts to Supabase.
# Requires the runs / run_events tables from supabase/run_events_schema.sql.
# Leave as `filesystem` to keep run logs under .logs/runs/ instead.
GRAPH_AGENT_RUN_STORE=supabase
# When GRAPH_AGENT_RUN_STORE=supabase: filesystem under .logs/runs/ is primary by default; Supabase is mirrored async.
# Set to 1 only if you need legacy behavior (reads/list_runs from Supabase, no local primary).
# GRAPH_AGENT_RUN_STORE_SUPABASE_PRIMARY=0
# Optional: HTTP timeout (seconds) for Supabase REST calls from the run store (default 10).
# GRAPH_AGENT_SUPABASE_RUN_STORE_TIMEOUT_SECONDS=10
# Mirror batching / flush wait (flush must exceed the HTTP timeout). Defaults scale with timeout.
# GRAPH_AGENT_RUN_STORE_MIRROR_EVENT_BATCH_SIZE=40
# GRAPH_AGENT_RUN_STORE_MIRROR_RUN_BATCH_SIZE=10
# GRAPH_AGENT_RUN_STORE_MIRROR_FLUSH_TIMEOUT_SECONDS=35
# Lean Supabase mirror (default 1): drops per-node history fields from runs.state_snapshot
# and only mirrors run.* / agent.run.* lifecycle events to run_events. The system+user
# prompts captured per api/provider node still land on runs.metadata.prompt_traces, and
# the filesystem store under .logs/runs/ keeps the full event log + state for local replay.
# Set to 0 to mirror the full state_snapshot and every event (heavier on Supabase storage).
# Forced off when GRAPH_AGENT_RUN_STORE_SUPABASE_PRIMARY=1.
# GRAPH_AGENT_RUN_STORE_SUPABASE_LEAN=1
# Default Supabase connection (also used by the run store when GRAPH_AGENT_RUN_STORE=supabase).
GRAPH_AGENT_SUPABASE_URL=
GRAPH_AGENT_SUPABASE_SECRET_KEY=
GRAPH_AGENT_SUPABASE_SCHEMA=public
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
# Optional: point the Supabase run store at a non-default env-var pair
# GRAPH_AGENT_RUN_STORE_SUPABASE_URL_ENV_VAR=GRAPH_AGENT_SUPABASE_URL
# GRAPH_AGENT_RUN_STORE_SUPABASE_SECRET_KEY_ENV_VAR=GRAPH_AGENT_SUPABASE_SECRET_KEY
# Example additional named graph-level connection values managed from the UI:
# GRAPH_AGENT_SUPABASE_ANALYTICS_URL=
# GRAPH_AGENT_SUPABASE_ANALYTICS_SECRET_KEY=
# SUPABASE_ANALYTICS_PROJECT_REF=
# SUPABASE_ANALYTICS_ACCESS_TOKEN=
